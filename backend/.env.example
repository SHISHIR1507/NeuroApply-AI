# ========================
# NeuroApply AI — Backend
# ========================

# --- Application ---
APP_NAME=NeuroApply AI
DEBUG=true

# --- PostgreSQL (with pgvector) ---
DATABASE_URL=postgresql+asyncpg://neuroapply:neuroapply_dev@localhost:5432/neuroapply
DATABASE_URL_SYNC=postgresql://neuroapply:neuroapply_dev@localhost:5432/neuroapply

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT Auth ---
JWT_SECRET_KEY=change-me-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- OpenAI API ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- CORS ---
CORS_ORIGINS=["chrome-extension://your-extension-id","http://localhost:3000"]

# Support emails (Raise an issue) — https://resend.com
RESEND_API_KEY=
RESEND_FROM=NeuroApply <onboarding@resend.dev>
SUPPORT_EMAIL=singhshishir4727@gmail.com
